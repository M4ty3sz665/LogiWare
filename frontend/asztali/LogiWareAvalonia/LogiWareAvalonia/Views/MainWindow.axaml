<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="clr-namespace:LogiWareAvalonia.ViewModels;assembly=LogiWareAvalonia"
		xmlns:models="using:LogiWareAvalonia.Classes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:views="clr-namespace:LogiWareAvalonia.Views"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="LogiWareAvalonia.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		RequestedThemeVariant="Dark"
		Icon="/Assets/avalonia-logo.ico"
		Title="LogiWareAvalonia">

	<Window.DataTemplates>
		

		<DataTemplate DataType="models:User">
			<Border Background="#2B2B30" Margin="0,0,0,10" Padding="15" CornerRadius="8">
				<Grid ColumnDefinitions="*, Auto">
					<WrapPanel Grid.Column="0">
						<Label Content="{Binding name}" 
							   FontWeight="Bold" 
							   FontSize="16" 
							   VerticalContentAlignment="Center" />
						<Label Content="{Binding email}" 
							   Foreground="Gray" 
							   FontSize="12" 
							   VerticalContentAlignment="Center" 
							   Margin="10,0,0,0"/>
						<Label Content="{Binding role}" 
							   Foreground="Gray" 
							   FontSize="12" 
							   VerticalContentAlignment="Center" 
							   Margin="10,0,0,0"/>
					</WrapPanel>
					<Button Grid.Column="1"
							Content="Edit"
							Width="80"
							Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditCommand}"
							CommandParameter="{Binding}"/>
				</Grid>
			</Border>
		</DataTemplate>

		<DataTemplate DataType="models:Stock">
			<Border Background="#2B2B30" 
					Margin="0,0,0,10" 
					Padding="15" 
					CornerRadius="8">
				<Grid ColumnDefinitions="*, Auto">
					<StackPanel Grid.Column="0">
						<TextBlock Text="{Binding id}" 
								   FontSize="16" 
								   FontWeight="Bold"/>
						<TextBlock Text="{Binding product_name}" 
								   FontSize="16"
								   FontWeight="Bold"/> 

						<TextBlock Text="{Binding amount, StringFormat='Quantity: {0}'}" 
						Foreground="Gray" 
						FontSize="12"/>
					</StackPanel>
					<Button Grid.Column="1"
							Content="Edit"
							Width="80"
							Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditCommand}"
							CommandParameter="{Binding}"/>
				</Grid>
			</Border>
		</DataTemplate>

<DataTemplate DataType="models:Order">
    <Border Background="#2B2B30" 
			Margin="0,0,0,10" 
			Padding="15" 
			CornerRadius="8">
        <StackPanel>
            <TextBlock FontSize="16">
                <Run Text="Order #" 
					 FontWeight="Bold"/>
                <Run Text="{Binding order_number}" 
					 FontWeight="Bold"/>
                <Run Text=" - "/>
                <Run Text="{Binding company_name}" 
					 FontStyle="Italic" 
					 Foreground="Gray"/>
            </TextBlock>
            <TextBlock  FontSize="12">
				<Run Text="{Binding status}"/>
				<Run Text="   Net "/>
				<Run Text="{Binding price_net}"/>
				<Run Text="   Gross "/>
				<Run Text="{Binding price_gross}"/>
				<Button Padding="3"
						HorizontalAlignment="Right"
						Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ViewCommand}">View</Button>
				<Button Padding="3"
						Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditCommand}"
						CommandParameter="{Binding}">Edit</Button>
			</TextBlock>
        </StackPanel>
    </Border>
</DataTemplate>
				<DataTemplate DataType="models:Product">
			<Border Background="#2B2B30" 
					Margin="0,0,0,10" 
					Padding="15" 
					CornerRadius="8">
				<Grid ColumnDefinitions="*, Auto">
					<StackPanel Grid.Column="0">
						<TextBlock FontSize="16.0">
					    <Run Text="{Binding id}" 
							 FontWeight="Bold"/>
					    <Run Text=" - "/>
					    <Run Text="{Binding name}" 
							 FontStyle="Italic" 
							 Foreground="Gray"/>
						</TextBlock>
						<TextBlock FontSize="12" 
								   FontWeight="SemiBold">
						<Run Text="Net "/>
						<Run Text="{Binding price_net}"/>
						<Run Text=" - "/>
						<Run Text="Gross "/>
						<Run Text="{Binding price_gross}"/>
						</TextBlock>
					</StackPanel>
					<Button Grid.Column="1"
							Content="Edit"
							Width="80"
							Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditCommand}"
							CommandParameter="{Binding}"/>
				</Grid>
			</Border>
		</DataTemplate>
	</Window.DataTemplates>

	<Window.Styles>
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Foreground" Value="White" />
		</Style>
		<Style Selector="Button">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="Padding" Value="0,10,0,10"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Margin" Value="0,0,0,5"/>
		</Style>
		<FluentTheme />

		<Style Selector="TextBlock.WindowCaption">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
	</Window.Styles>

<Grid Background="#2B2B30">
        <Grid IsVisible="{Binding !IsMobileView}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="10" Background="#1E1E22" CornerRadius="12" Padding="10">
                <Grid RowDefinitions="*, Auto">
                    <StackPanel Spacing="5">
                        <TextBlock Text="LogiWare Desktop" Margin="10,0,0,20" FontWeight="Bold" Opacity="0.5"/>
                        <Button Command="{Binding UsersButtonClick}" Content="Users" />
                        <Button Command="{Binding StockButtonClick}" Content="Stock" />
                        <Button Command="{Binding OrdersButtonClick}" Content="Orders" />
                        <Button Command="{Binding ProductsButtonClick}" Content="Products"/>
                    </StackPanel>
                    <Button Grid.Row="1" Command="{Binding LogOutClick}" Content="Exit" Background="#CC3333"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="5,10,10,10" Background="#1E1E22" CornerRadius="12" Padding="20">
                <Grid RowDefinitions="Auto, *">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="{Binding TitleLabel}" FontSize="24" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="New" Width="100" Background="#7A3CFF" Command="{Binding NewItemCommand}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="0,15,0,0">
                        <ItemsControl ItemsSource="{Binding CurrentItems}" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsMobileView}" RowDefinitions="Auto, *, Auto">
            <Border Grid.Row="0" Background="#1E1E22" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="{Binding TitleLabel}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+" Width="40" Background="#7A3CFF" Command="{Binding NewItemCommand}"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="10">
                <ItemsControl ItemsSource="{Binding CurrentItems}" />
            </ScrollViewer>

            <Border Grid.Row="2" Background="#1E1E22" Padding="5" CornerRadius="15,15,0,0">
                <UniformGrid Columns="4">
                    <Button Command="{Binding UsersButtonClick}" Background="Transparent" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="👤" HorizontalAlignment="Center"/>
                            <TextBlock Text="Users" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StockButtonClick}" Background="Transparent" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="📦" HorizontalAlignment="Center"/>
                            <TextBlock Text="Stock" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OrdersButtonClick}" Background="Transparent" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="📋" HorizontalAlignment="Center"/>
                            <TextBlock Text="Orders" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ProductsButtonClick}" Background="Transparent" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="🏷️" HorizontalAlignment="Center"/>
                            <TextBlock Text="Items" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </Border>
        </Grid>
    </Grid>
</Window>